<?xml version="1.0"?>
<robot name="custom_robot_arm">

  <!-- ======================== MATERIALS ======================== -->
  <material name="orange">
    <color rgba="1.0 0.45 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.65 0.65 0.65 1.0"/>
  </material>

  <!-- ======================== BASE ======================== -->
  <!-- 5cm radius, 5.5cm tall -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0275" rpy="0 0 0"/>
      <geometry><cylinder radius="0.050" length="0.055"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0275" rpy="0 0 0"/>
      <geometry><cylinder radius="0.050" length="0.055"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.0275" rpy="0 0 0"/>
      <mass value="0.200"/>
      <inertia ixx="0.000183" ixy="0" ixz="0"
               iyy="0.000183" iyz="0"
               izz="0.000160"/>
    </inertial>
  </link>

  <!-- ======================== JOINT 1: BASE ROTATE ======================== -->
  <!-- MG996R servo, Z-axis, rotates arm left/right -->
  <!-- Servo 0°=left, 90°=forward, 180°=right -->
  <joint name="base_rotate" type="revolute">
    <parent link="base_link"/>
    <child  link="base_rotator_link"/>
    <origin xyz="0 0 0.055" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.8" velocity="3.14"/>
    <dynamics damping="0.10" friction="0.05"/>
  </joint>

  <!-- Base rotator: 3cm tall (base to shoulder gap) -->
  <link name="base_rotator_link">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><cylinder radius="0.020" length="0.030"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><cylinder radius="0.020" length="0.030"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="0.000012" ixy="0" ixz="0"
               iyy="0.000012" iyz="0"
               izz="0.000008"/>
    </inertial>
  </link>

  <!-- ======================== JOINT 2: SHOULDER ======================== -->
  <!--
    FIX: Changed axis from "1 0 0" (X) to "0 1 0" (Y).

    With X-axis, the shoulder would swing the arm sideways (left/right in frontal plane).
    That contradicts "X = forward": for the arm to reach forward, the shoulder
    must pitch forward/backward, which requires rotation around the Y-axis.

    Servo 0°=tilted back, 90°=straight up, 180°=tilted forward
    IK positive angle = forward tilt = servo increases... but our mapping is
    servo = 90 - degrees(ik), so IK positive = servo decreases.
    This means IK positive = tilted back. That's fine — the solver figures it out.

    IF YOUR PHYSICAL ROBOT TRULY HAS THE SHOULDER SWINGING SIDEWAYS ON X-AXIS,
    CHANGE THIS BACK TO "1 0 0" — but then "X = forward" won't work intuitively.
  -->
  <joint name="shoulder_joint" type="revolute">
    <parent link="base_rotator_link"/>
    <child  link="upper_arm_link"/>
    <origin xyz="0 0 0.030" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.8" velocity="3.14"/>
    <dynamics damping="0.10" friction="0.05"/>
  </joint>

  <!-- Upper arm: 12cm long -->
  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 0.060" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.120"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.060" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.120"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.060" rpy="0 0 0"/>
      <mass value="0.080"/>
      <inertia ixx="0.000097" ixy="0" ixz="0"
               iyy="0.000097" iyz="0"
               izz="0.000005"/>
    </inertial>
  </link>

  <!-- ======================== JOINT 3: ELBOW ======================== -->
  <!--
    FIX: Changed axis from "1 0 0" (X) to "0 1 0" (Y) to match shoulder.

    The elbow bends in the same plane as the shoulder. Since the shoulder now
    rotates around Y, the elbow must also rotate around Y to stay in-plane.
  -->
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child  link="forearm_link"/>
    <origin xyz="0 0 0.120" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.8" velocity="3.14"/>
    <dynamics damping="0.10" friction="0.05"/>
  </joint>

  <!-- Forearm: 9cm long -->
  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.090"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.090"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <mass value="0.060"/>
      <inertia ixx="0.000041" ixy="0" ixz="0"
               iyy="0.000041" iyz="0"
               izz="0.000004"/>
    </inertial>
  </link>

  <!-- ======================== JOINT 4: WRIST ROLL ======================== -->
  <!-- SG90 servo, Z-axis, twists along forearm axis -->
  <joint name="wrist_roll_joint" type="revolute">
    <parent link="forearm_link"/>
    <child  link="wrist_roll_link"/>
    <origin xyz="0 0 0.090" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="0.18" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="wrist_roll_link">
    <visual>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.015" length="0.025"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry><cylinder radius="0.015" length="0.025"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <mass value="0.014"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <!-- ======================== JOINT 5: WRIST PITCH ======================== -->
  <!-- SG90 servo, Y-axis, tilts gripper up/down -->
  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="wrist_roll_link"/>
    <child  link="wrist_pitch_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="0.18" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="wrist_pitch_link">
    <visual>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <geometry><box size="0.025 0.025 0.020"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <geometry><box size="0.025 0.025 0.020"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <mass value="0.014"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <!-- ======================== GRIPPER BASE ======================== -->
  <!-- Fixed joint: wrist pitch → gripper base (3cm) -->
  <joint name="wrist_to_gripper" type="fixed">
    <parent link="wrist_pitch_link"/>
    <child  link="gripper_base_link"/>
    <origin xyz="0 0 0.030" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <geometry><box size="0.030 0.035 0.020"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <geometry><box size="0.030 0.035 0.020"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="0.000003" ixy="0" ixz="0"
               iyy="0.000003" iyz="0"
               izz="0.000004"/>
    </inertial>
  </link>

  <!-- ======================== JOINT 6: GRIPPER ======================== -->
  <!--
    FIX: Changed both finger joints to "fixed" type.

    Reason: roboticstoolbox does NOT handle URDF <mimic> joints.
    If these are revolute, the IK solver treats them as independent DOFs
    and wastes computation trying to optimize finger positions.
    Since the gripper is controlled separately (servo command, not IK),
    fixing these joints is correct.

    The fingers are shown in their open position for visualization.
  -->
  <joint name="left_finger_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child  link="left_finger_link"/>
    <origin xyz="-0.005 0 0.020" rpy="0 0.25 0"/>
  </joint>

  <link name="left_finger_link">
    <visual>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry><box size="0.008 0.015 0.065"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry><box size="0.008 0.015 0.065"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <mass value="0.008"/>
      <inertia ixx="0.000003" ixy="0" ixz="0"
               iyy="0.000003" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="right_finger_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child  link="right_finger_link"/>
    <origin xyz="0.005 0 0.020" rpy="0 -0.25 0"/>
  </joint>

  <link name="right_finger_link">
    <visual>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry><box size="0.008 0.015 0.065"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry><box size="0.008 0.015 0.065"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <mass value="0.008"/>
      <inertia ixx="0.000003" ixy="0" ixz="0"
               iyy="0.000003" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

</robot>
